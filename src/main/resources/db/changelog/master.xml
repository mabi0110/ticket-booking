<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.2.xsd">
    <changeSet id="0001" author="mabi">
        <createTable tableName="movie">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="title" type="VARCHAR(100)"/>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="duration_min" type="INT"/>
        </createTable>
    </changeSet>
    <changeSet id="0002" author="mabi">
        <createTable tableName="screening">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="screening_time" type="datetime"/>
            <column name="movie_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="screening"
                                 baseColumnNames="movie_id"
                                 constraintName="fk_screening_movie_id"
                                 referencedTableName="movie"
                                 referencedColumnNames="id"/>
    </changeSet>
    <changeSet id="0003" author="mabi">
        <createTable tableName="room">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>
    <changeSet id="0004" author="mabi">
        <createTable tableName="seat">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="column" type="VARCHAR(10)"/>
            <column name="row" type="INT"/>
            <column name="room_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="seat"
                                 baseColumnNames="room_id"
                                 constraintName="fk_seat_room_id"
                                 referencedTableName="room"
                                 referencedColumnNames="id"/>
    </changeSet>
    <include file="../testdata/testdata.sql" relativeToChangelogFile="true"/>
</databaseChangeLog>